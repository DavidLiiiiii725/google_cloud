# Shared blackboard + the database the Gemini->MongoDB MCP bridge operates on.
# Default is a LOCAL real mongod (scripts\install-mongo.ps1 to install, run.ps1 starts
# it). We use local mongod because MongoDB Atlas is TLS-blocked on this network — the
# handshake is killed by GFW interference (both Python and Node fail identically).
# If you have a reachable Atlas cluster, point MONGODB_URI at it (mongodb+srv://...).
MONGODB_URI=mongodb://127.0.0.1:27017/?directConnection=true
MONGODB_DB=agent_greenhouse

# Google Cloud (ADC — run `gcloud auth application-default login`).
# GCP_PROJECT must be a project the ADC identity can actually call Vertex on, and
# GEMINI_MODEL must be served there. The 2.5 family is broadly available; older
# IDs like gemini-2.0-flash-001 may 404 depending on the project.
GCP_PROJECT=farmer-hackathon 
GCP_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Optional: leave unset to fall back to local /assets/ images
# GCS_BUCKET=

# How the Transport Agent reaches the OR-Tools optimizer. run.ps1 sets this for you.
OPTIMIZER_URL=http://localhost:8080

# Optional: real driving distances in the optimizer. Falls back to haversine if unset.
# GOOGLE_MAPS_API_KEY=
